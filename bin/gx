#!/usr/bin/env bash
# gx â€” gaspol codegen delegate. Jalan A: Claude pegang otak (plan/spec/review/commit),
# script ini tangan codegen via opencode. Session-aware: handover = arahin ke plan file
# YANG SUDAH ADA (atau brief inline), lalu delta-continue untuk iterative fix.
#
# TWO EXECUTION MODES:
#   gx <plan.md|"brief">            # SOLO   â†’ --agent coder   (deepseek writes directly)
#   gx --team <plan.md|"brief">     # TWO-TIERâ†’ --agent executor (GLM lead â†’ @coder deepseek)
#   gx "delta"                      # CONTINUE active session (reuses its agent)
#
# POOL (which model pair) comes from the session mode marker ~/.config/model-router/mode:
#   opencode (default) â†’ executor/coder  = opencode-go glm-5.2 + deepseek-v4-pro ; failover â†’ ollama
#   ollama             â†’ executor-ff/coder-ff = ollama glm-5.2 + kimi-k2.7-code  ; failover â†’ opencode
# The agent's OWN config (opencode.jsonc) carries the model â€” gx does NOT pass -m unless you
# explicitly override (e.g. mechanical mass-edit: gx -m opencode-go/deepseek-v4-flash "â€¦").
#
# Usage:
#   gx docs/plans/<plan>.md ["gate"]   # START from a plan file (solo)
#   gx --team docs/plans/<plan>.md     # START two-tier (GLM lead)
#   gx --new <plan.md|"brief">         # START (reset even if a session is active)
#   gx --new - <<'EOF' â€¦ EOF           # START from multiline stdin brief
#   gx "delta"                         # CONTINUE active session
#   gx --end | --print-session | --print-model
#   gx -m <provider/model> â€¦           # explicit model override (pins to the session)
#
# NOTE: ollama pool models need `ollama signin`. ponytail: thin wrapper, no getopts lib.
set -euo pipefail

MFLAG=""          # explicit -m override; empty = let the agent config drive the model
PRINT_MODEL=0
NEW=0; END=0; PRINT_SESSION=0; TEAM=0
declare -a POS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -m|--model)       MFLAG="$2"; shift 2 ;;
    --team)           TEAM=1; shift ;;
    --print-model)    PRINT_MODEL=1; shift ;;
    --new)            NEW=1; shift ;;
    --end)            END=1; shift ;;
    --print-session)  PRINT_SESSION=1; shift ;;
    --)               shift; POS+=("$@"); break ;;
    *)                POS+=("$1"); shift ;;
  esac
done

# POOL from the session mode marker (Phase 6). Default opencode. anthropic-* modes don't use gx.
MODE_MARKER="${ROUTER_MODE:-$HOME/.config/model-router/mode}"
POOL="opencode"
if [[ -s "$MODE_MARKER" ]]; then
  m="$(<"$MODE_MARKER")"; m="${m//[$'\n\r']/}"
  [[ "$m" == ollama ]] && POOL="ollama"
fi

# agent (+ its failover partner) from pool Ă— mode. Solo = coder tier; team = executor lead tier.
if [[ "$POOL" == ollama ]]; then
  if [[ "$TEAM" == 1 ]]; then PRIMARY_AGENT="executor-ff"; FAILOVER_AGENT="executor"
  else                        PRIMARY_AGENT="coder-ff";    FAILOVER_AGENT="coder"; fi
else
  if [[ "$TEAM" == 1 ]]; then PRIMARY_AGENT="executor";    FAILOVER_AGENT="executor-ff"
  else                        PRIMARY_AGENT="coder";       FAILOVER_AGENT="coder-ff"; fi
fi

[[ "$PRINT_MODEL" == 1 ]] && { echo "agent=$PRIMARY_AGENT pool=$POOL${MFLAG:+ mflag=$MFLAG}"; exit 0; }

# stream: pipe opencode `--format json` through oc-stream â†’ clean live event lines (delegation,
# tool, file, text) so the executor's work shows in the terminal/chat instead of running silent.
# Disable with GX_NOSTREAM=1 (raw opencode output). pipefail makes opencode's non-zero propagate.
OC_STREAM="$(command -v oc-stream 2>/dev/null || true)"
oc_run() {  # all args â†’ `opencode run`
  if [[ -n "$OC_STREAM" && -z "${GX_NOSTREAM:-}" ]]; then
    opencode run "$@" --format json | "$OC_STREAM"
  else
    opencode run "$@"
  fi
}

# per-repo active-session pointer, OUTSIDE the repo (zero repo footprint)
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/gx"
mkdir -p "$STATE_DIR"
REPO="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
PTR="$STATE_DIR/$(printf %s "$REPO" | shasum | cut -c1-12).session"

[[ "$END" == 1 ]] && { rm -f "$PTR"; echo "gx: session ended" >&2; exit 0; }
if [[ "$PRINT_SESSION" == 1 ]]; then
  [[ -s "$PTR" ]] && cut -f1 "$PTR" || { echo "gx: no active session" >&2; exit 1; }
  exit 0
fi

# MODE: --new OR a positional file â†’ START ; else a message â†’ CONTINUE
MODE=""
if   [[ "$NEW" == 1 ]];                        then MODE=start
elif [[ ${#POS[@]} -gt 0 && -f "${POS[0]}" ]]; then MODE=start   # legacy positional-file
elif [[ ${#POS[@]} -gt 0 ]];                   then MODE=continue
else echo "gx: butuh input. Usage: gx [--team] <plan.md|\"brief\">  |  gx \"delta\"  |  gx --end" >&2; exit 2; fi

DEFAULT_GATE="Load CLAUDE.md (Â§16 routes/tables) + the attached spec. Implement it exactly. Gate: no placeholder/TODO/mock, follow Â§12 anti-slop + Â§6 conventions. Write AND run tests to green. Edit files only â€” do not commit."

# build the -m override arg once (empty unless the user passed -m)
declare -a MFLAG_ARGS=(); [[ -n "$MFLAG" ]] && MFLAG_ARGS=(-m "$MFLAG")

if [[ "$MODE" == start ]]; then
  SPEC=""; SLUG=""; PROMPT=""
  src="${POS[0]:-}"
  if [[ "$src" == "-" ]]; then
    PROMPT="$(cat)"; SLUG="adhoc-$(date +%H%M%S)"
  elif [[ -n "$src" && -f "$src" ]]; then
    SPEC="$src"; SLUG="$(basename "$src")"; SLUG="${SLUG%.md}"
    rest=("${POS[@]:1}"); PROMPT="${rest[*]:-$DEFAULT_GATE}"
  else
    PROMPT="${POS[*]}"; SLUG="adhoc-$(date +%H%M%S)"   # inline brief (user bakes the gate in)
  fi
  [[ -n "$PROMPT" ]] || { echo "gx: empty brief" >&2; exit 2; }

  run_start() {  # $1 = agent
    if [[ -n "$SPEC" ]]; then
      oc_run "$PROMPT" --agent "$1" ${MFLAG_ARGS[@]+"${MFLAG_ARGS[@]}"} --title "gx:$SLUG" -f "$SPEC"
    else
      oc_run "$PROMPT" --agent "$1" ${MFLAG_ARGS[@]+"${MFLAG_ARGS[@]}"} --title "gx:$SLUG"
    fi
  }

  # auto-failover: primary agent (its pool) fails â†’ retry ONCE on the failover-pool agent.
  # Never loops (failover agent is invoked at most once).
  USED_AGENT="$PRIMARY_AGENT"
  echo "gx â†’ start | agent=$PRIMARY_AGENT pool=$POOL$([[ "$TEAM" == 1 ]] && echo ' (two-tier)') | title=gx:$SLUG | ${SPEC:+spec=$SPEC}${SPEC:-inline brief}" >&2
  if ! run_start "$PRIMARY_AGENT"; then
    echo "gx: $PRIMARY_AGENT failed â†’ failover $FAILOVER_AGENT (pool dead)" >&2
    run_start "$FAILOVER_AGENT" || { echo "gx: failover also failed" >&2; exit 1; }
    USED_AGENT="$FAILOVER_AGENT"
  fi

  # capture the just-created session id by its exact title (robust vs interleaving)
  SID="$(opencode session list --format json 2>/dev/null | jq -r --arg t "gx:$SLUG" '[.[]|select(.title==$t)]|.[0].id // empty' 2>/dev/null || true)"
  if [[ -n "$SID" ]]; then
    printf '%s\t%s\n' "$SID" "$USED_AGENT" > "$PTR"
    echo "gx: session $SID pinned (agent=$USED_AGENT; continue with: gx \"<delta>\")" >&2
  else
    echo "gx: warn â€” could not capture session id (continue by --new next time)" >&2
  fi

else  # MODE == continue
  [[ -s "$PTR" ]] || { echo "gx: no active session â€” start with: gx [--team] <plan.md|\"brief\">" >&2; exit 2; }
  SID="$(cut -f1 "$PTR")"; SAGENT="$(cut -f2 "$PTR")"; SAGENT="${SAGENT:-coder}"
  DELTA="${POS[*]}"
  echo "gx â†’ continue | session=$SID | agent=$SAGENT" >&2
  # ponytail: no continue-failover â€” resuming a thread on the other pool mid-session is incoherent;
  # on failure start fresh on the other pool via --new.
  oc_run "$DELTA" --agent "$SAGENT" ${MFLAG_ARGS[@]+"${MFLAG_ARGS[@]}"} -s "$SID" \
    || { echo "gx: continue failed (session $SID). Start fresh: gx --new <plan.md|\"brief\">" >&2; exit 1; }
fi

echo "--- gx done. Review diff before commit: ---" >&2
git --no-pager diff --stat
